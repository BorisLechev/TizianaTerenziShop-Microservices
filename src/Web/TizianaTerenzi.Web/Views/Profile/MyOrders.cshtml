@inject IViewLocalizer Localizer
@model IEnumerable<OrdersListingViewModel>

@{
    this.ViewData["Title"] = Localizer["My orders"];
}

<div class="container" style="margin-top: 100px;">
    <div class="mx-auto my-4">
        <div class="text-center mb-3">
            <h2>@ViewData["Title"]</h2>
        </div>

        <table class="table table-hover dt-responsive dataTable nowrap" style="width: 100%;">
            <thead>
                <tr class="font-weight-bold">
                    <th>@Localizer["Full name"]</th>
                    <th>@Localizer["Order Date"]</th>
                    <th>@Localizer["Total price"]</th>
                    <th>@Localizer["Discount code name"]</th>
                    <th>%</th>
                    <th>@Localizer["Status"]</th>
                    <th>@Localizer["Actions"]</th>
                    <th>PDF</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.UserFullName</td>
                        <td><time datetime="@order.CreatedOn.ToString("O")"></time></td>
                        <td>@order.TotalPrice</td>
                        @if (order.DiscountCodeName != null)
                        {
                            <td>@order.DiscountCodeName</td>
                        }
                        else
                        {
                            <td></td>
                        }
                        <td>@order.DiscountCodeDiscount</td>
                        <td>@order.StatusName</td>
                        <td>
                            <a class="btn btn-outline-primary" href="/profile/order/@order.Id">
                                <i class="fas fa-pen"></i>
                                @Localizer["Products"]
                            </a>
                        </td>
                        <td>
                            <a class="btn btn-outline-success" asp-area="" asp-controller="Profile" asp-action="GeneratePdf" asp-route-orderId="@order.Id">
                                <i class="fas fa-file-pdf"></i>
                                PDF
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>