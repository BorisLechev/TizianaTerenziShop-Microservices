
<div class="card mb-4">
    <img class="card-img-top" src="https://res.cloudinary.com/dxfq3iotg/image/upload/v1574583246/AAA/2.jpg" alt="Card image cap">
    @*<i class="fas fa-user fa-3x mb-4 text-primary text-center pt-4"></i>*@
    <div class="card-body text-center">
        <h5 class="card-title">@@@this.Model.UserName</h5>

        @if (this.User.Identity.Name == this.Model.UserName)
        {
            <a asp-area="" asp-controller="Profile" asp-action="Index" asp-route-userId="@this.Model.Id" class="btn btn-success">
                <span><i class="fas fa-user"></i> My Profile</span>
            </a>
        }
        else
        {
            <a asp-area="" asp-controller="Profile" asp-action="Index" asp-route-userId="@this.Model.Id" class="btn btn-primary">
                <span><i class="fas fa-user"></i> View Profile</span>
            </a>
        }
    </div>
</div>