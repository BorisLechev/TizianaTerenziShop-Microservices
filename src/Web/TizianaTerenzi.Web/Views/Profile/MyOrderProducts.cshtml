@inject IViewLocalizer Localizer
@model IEnumerable<OrderProductsListingViewModel>

@{
    ViewData["Title"] = Localizer["My order products"];
}

<div class="container" style="margin-top: 100px;">
    <div class="mx-auto my-4">
        <div class="text-center mb-3">
            <h2>@ViewData["Title"]</h2>
        </div>

        <table class="table table-hover dt-responsive dataTable nowrap" style="width: 100%;">
            <thead>
                <tr class="font-weight-bold">
                    <th>@Localizer["Product"]</th>
                    <th>@Localizer["Order Date"]</th>
                    <th>@Localizer["Quantity"]</th>
                    <th>@Localizer["Price"]</th>
                    <th>@Localizer["Total price"]</th>
                    <th>@Localizer["Discount code name"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in this.Model)
                {
                    <tr>
                        <td>@product.ProductName</td>
                        <td><time datetime="@product.CreatedOn.ToString("O")"></time></td>
                        <td>@product.Quantity</td>
                        <td>@product.Price</td>
                        <td>@product.TotalPrice</td>
                        @if (product.OrderDiscountCodeDiscount != null)
                        {
                            <td>@product.OrderDiscountCodeDiscount</td>
                        }
                        else
                        {
                            <td></td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>