@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model UserGitHubRegisterInputModel

@{
    ViewData["Title"] = "Complete registration";
}

<div class="text-center w-75 w-md-50 mx-auto github-register-wrapper">
    <i class="fab fa-github fa-3x"></i>

    <h2>@ViewData["Title"]</h2>

    <p>We need some more information to complete your registration with GitHub</p>

    <form asp-controller="Authentication" asp-action="GitHubRegister" asp-action-returnUrl="@ViewData["ReturnUrl"]" method="post">
        <hr />
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="form-group">
            <label asp-for="@Model.Email"></label>
            <input class="form-control" asp-for="@Model.Email" />
            <span asp-validation-for="@Model.Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="@Model.FirstName"></label>
            <input class="form-control" asp-for="@Model.FirstName" />
            <span asp-validation-for="@Model.FirstName" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="@Model.LastName"></label>
            <input class="form-control" asp-for="@Model.LastName" />
            <span asp-validation-for="@Model.LastName" class="text-danger"></span>
        </div>
        <div class="form-group">
            <input type="hidden" id="RecaptchaValue" name="RecaptchaValue" />
        </div>
        <div class="form-group">
            <button type="submit" class="btn btn-primary w-100 p-3 d-block">Complete registration</button>
            <small>
                By clicking the above button, you agree to our
                <a asp-controller="Home" asp-action="Terms">Terms and conditions</a> and
                <a asp-controller="Home" asp-action="Privacy">Privacy policy</a>
            </small>
        </div>
    </form>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script src="https://www.google.com/recaptcha/api.js?render=@this.Configuration["GoogleReCaptcha:Key"]"></script>
    <script>
        grecaptcha.ready(function () {
            grecaptcha.execute('@this.Configuration["GoogleReCaptcha:Key"]', { action: 'login_form' }).then(function (token) {
                document.getElementById("RecaptchaValue").value = token;
            });
        });
    </script>
}

@section CustomCss {
    <style>
        .github-register-wrapper {
            padding-top: 100px;
        }
    </style>
}