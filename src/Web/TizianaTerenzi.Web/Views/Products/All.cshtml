@model ProductsWithPaginationListingViewModel

@{

}

<div class="main">
    <section class="container">
        <section class="row">
            <section class="inner-row">
                <section class="products-list-container">
                    <section class="products-list">
                        @foreach (var product in Model.Products)
                        {
                            <article class="items-col">
                                <section class="wrapper-item">
                                    <section class="wrapper-item-inner">
                                        <section class="product-image-container">
                                            <a class="product-image-link" href="@product.Url" title="@product.Name">
                                                <img class="product-image front" src="@product.Picture" alt="@product.Name">
                                                <img class="product-image back" src="@product.Picture" alt="@product.Name">
                                                <section class="image-overlay"></section>
                                            </a>
                                        </section>
                                        <section class="actions">
                                            <div class="link-actions"></div>
                                            <form asp-area="" asp-controller="Cart" asp-action="AddProductInTheCart" asp-route-productId="@product.Id" method="post">
                                                <button class="btn-cart" type="submit">Add to Cart</button>
                                            </form>
                                            <button class="btn-edit">
                                                <span>Edit Product</span>
                                            </button>
                                            <button class="button-delete">
                                                <span>Delete Product</span>
                                            </button>
                                        </section>
                                    </section>
                                    <section class="product-info">
                                        <a title="@product.Name" href="@product.Url">
                                            <header>
                                                <h6 class="product-name">
                                                    <span>@product.Name</span>
                                                </h6>
                                            </header>
                                            <footer class="price-box">
                                                <span class="price">EUR @product.Price</span>
                                            </footer>
                                        </a>
                                    </section>
                                </section>
                            </article>
                        }
                    </section>
                </section>
            </section>
        </section>
    </section>
</div>

<div class="pagination-container">
    <nav>
        <ul class="pagination justify-content-center">
            @if (this.Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-controller="Products" asp-action="All" asp-route-page="@this.Model.PreviousPage" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
            }
            @{
                const int MorePagesToShow = 3;
                var pagesToShow = new List<int>();

                for (int i = 1; i <= MorePagesToShow; i++)
                {
                    pagesToShow.Add(i);
                }
                for (int i = this.Model.CurrentPage - MorePagesToShow; i <= this.Model.CurrentPage + MorePagesToShow; i++)
                {
                    if (i > 0)
                    {
                        pagesToShow.Add(i);
                    }
                }
                for (int i = this.Model.PagesCount - MorePagesToShow + 1; i <= this.Model.PagesCount; i++)
                {
                    if (i > 0)
                    {
                        pagesToShow.Add(i);
                    }
                }

                pagesToShow = pagesToShow.Where(x => x <= this.Model.PagesCount).Distinct().OrderBy(x => x).ToList();
            }

            @for (int i = 0; i < pagesToShow.Count; i++)
            {
                var className = string.Empty;
                var pageNumber = pagesToShow[i];

                if (pageNumber == this.Model.CurrentPage)
                {
                    className = "active";
                }
                if (i > 0 && pageNumber - 1 != pagesToShow[i - 1]) // inache ima i chislo i predi nego "..." pak kam sashtata stranica
                {
                    <li class="page-item @className">
                        <a class="page-link"
                           asp-controller="Products"
                           asp-action="All"
                           asp-route-page="@(pagesToShow[i - 1] + 1)">...</a>
                    </li>
                }
                <li class="page-item @className">
                    <a class="page-link"
                       asp-controller="Products"
                       asp-action="All"
                       asp-route-page="@pageNumber">@pageNumber</a>
                </li>
            }

            @if (this.Model.CurrentPage < this.Model.PagesCount)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-controller="Products"
                       asp-action="All"
                       asp-route-page="@this.Model.NextPage"
                       aria-label="Next">&raquo;</a>
                </li>
            }
        </ul>
    </nav>
</div>

<partial name="_TestimonialsPartial" />
@*<partial name="_SubscribeNewsletterPartial" />*@

@section CustomCss {
    <link href="~/css/products.css" rel="stylesheet" asp-append-version="true" />
}