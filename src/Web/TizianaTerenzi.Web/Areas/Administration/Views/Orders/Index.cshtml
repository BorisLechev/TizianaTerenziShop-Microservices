@model IEnumerable<OrdersListingViewModel>

@{
    ViewData["Title"] = "All orders";
}

<div class="container all-orders-wrapper">
    <div class="mx-auto my-4">
        <div class="text-center mb-3">
            <h2>@ViewData["Title"]</h2>
        </div>

        <table class="table table-hover dt-responsive dataTable nowrap" style="width: 100%;">
            <thead>
                <tr class="font-weight-bold">
                    <th>Fullname</th>
                    <th>Order Date</th>
                    <th>Total price</th>
                    <th>Discount code name</th>
                    <th>%</th>
                    <th>Status</th>
                    <th colspan="2">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.UserFullName</td>
                        <td><time datetime="@order.CreatedOn.ToString("O")"></time></td>
                        <td>@order.TotalPrice</td>
                        @if (order.DiscountCodeName != null)
                        {
                            <td>@order.DiscountCodeName</td>
                        }
                        else
                        {
                            <td></td>
                        }
                        <td>@order.DiscountCodeDiscount</td>
                        <td>@order.StatusName</td>
                        <td>
                            <a class="btn btn-outline-primary" asp-area="Administration" asp-controller="Orders" asp-action="Products" asp-route-orderId="@order.Id">
                                <i class="fas fa-info"></i>
                                Products
                            </a>
                        </td>
                        <td>
                            @if (order.StatusName == "Pending")
                            {
                                <a class="btn btn-outline-success" asp-area="Administration" asp-controller="Orders" asp-action="Process" asp-route-orderId="@order.Id">
                                    <i class="fas fa-check"></i>
                                    Process
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="chart-container"></div>
</div>
<form id="chartForm" method="post"></form>

@section CustomCss {
    <style>
        .all-orders-wrapper {
            padding-top: 100px;
        }
    </style>
}

@section Scripts {
    <script src="~/lib/highcharts/highcharts.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let token = $("#chartForm input[name=__RequestVerificationToken]").val();

            $.ajax({
                url: "/administration/api/charts",
                type: "GET",
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                headers: { 'X-CSRF-TOKEN': token },
                success: function (data) {
                    let currentDayOrders = [];
                    let previousDayOrders = [];
                    let theDayBeforeYesterdayOrders = [];
                    let currentDay = moment().local().format("dddd");
                    let previousDay = moment().local().subtract(1, "day").format("dddd");
                    let theDayBeforeYesterday = moment().local().subtract(2, "day").format("dddd");

                    for (var order of data.orders) {
                        let day = moment.utc(order.createdOn).local().format("dddd");

                        if (day === currentDay) {
                            currentDayOrders.push(order);
                        } else if (day === previousDay) {
                            previousDayOrders.push(order);
                        } else if (day === theDayBeforeYesterday) {
                            theDayBeforeYesterdayOrders.push(order);
                        }
                    }

                    createChart(currentDay, previousDay, theDayBeforeYesterday, currentDayOrders.length, previousDayOrders.length, theDayBeforeYesterdayOrders.length);
                }
            });
        });

        function createChart(currentDay, previousDay, theDayBeforeYesterday, currentDayOrders, previousDayOrders, theDayBeforeYesterdayOrders) {
            Highcharts.chart({
                chart: {
                    type: 'column',
                    renderTo: 'chart-container'
                },
                title: {
                    text: 'Orders count for the last 3 days'
                },
                yAxis: {
                    min: 0,
                    title: {
                        text: 'Orders count'
                    }
                },
                xAxis: {
                    categories: [
                        currentDay,
                        previousDay,
                        theDayBeforeYesterday,
                    ],
                    crosshair: true
                },
                plotOptions: {
                    column: {
                        pointPadding: 0.2,
                        borderWidth: 0
                    }
                },
                series: [{
                    name: currentDay,
                    data: [currentDayOrders],
                }, {
                    name: previousDay,
                    data: [previousDayOrders],
                }, {
                    name: theDayBeforeYesterday,
                    data: [theDayBeforeYesterdayOrders],
                }],
                responsive: {
                    rules: [{
                        condition: {
                            maxWidth: 500
                        }
                    }]
                }
            });
        }
    </script>
}