@model EditProductInputModel

@{
    ViewData["Title"] = "Edit a Product";
}

<div class="w-75 w-md-50 text-center mx-auto create-product-wrapper">
    <div class="row space-top">
        <div class="col-md-12">
            <h2 class="title">@ViewData["Title"]</h2>
        </div>
    </div>
    <hr />
    <div asp-validation-summary="All" class="text-danger"></div>
    <form method="post" enctype="multipart/form-data">
        <section class="form-group">
            <label asp-for="@this.Model.Name">Name</label>
            <section class="field mb-4">
                <input asp-for="@this.Model.Name" class="form-control" placeholder="Name" type="text" />
                <span asp-validation-for="@this.Model.Name" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="@this.Model.ProductTypeId" class="control-label">Product Type</label>
            <section class="field mb-4">
                <select id="productType" class="form-control" title="Select Product Type..." asp-for="@this.Model.ProductTypeId" asp-items="@this.Model.ProductTypes">
                </select>
                <span asp-validation-for="@this.Model.ProductTypeId" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="@this.Model.FragranceGroupId" class="control-label">Fragrance Group</label>
            <section class="field mb-4">
                <select id="fragranceGroup" class="form-control selectpicker" data-live-search="true" title="Select Fragrance Group..." asp-for="@this.Model.FragranceGroupId" asp-items="@this.Model.FragranceGroups">
                </select>
                <span asp-validation-for="@this.Model.FragranceGroupId" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="@this.Model.NoteIds" class="control-label">Notes</label>
            <section class="field mb-4">
                <select id="note" class="form-control selectpicker" data-live-search="true" multiple title="Select Notes..." asp-for="@this.Model.NoteIds" asp-items="@this.Model.Notes">
                </select>
                <span asp-validation-for="@this.Model.NoteIds" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="@this.Model.Description">Description</label>
            <section class="field mb-4">
                <textarea asp-for="@this.Model.Description" class="form-control"></textarea>
                <span asp-validation-for="@this.Model.Description" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="@this.Model.Price">Price</label>
            <section class="field mb-4">
                <input class="form-control" asp-for="@this.Model.Price" placeholder="Price" type="number" />
                <span asp-validation-for="@this.Model.Price" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="@this.Model.Picture">Image file</label>
            <section class="field mb-4">
                <div class="custom-file">
                    <input asp-for="@this.Model.Picture" id="customFile" class="custom-file-input form-control" type="file">
                    <label class="custom-file-label" for="customFile">Choose file</label>
                </div>
                <span asp-validation-for="@this.Model.Picture" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="@this.Model.YearOfManufacture">Year of manufacture</label>
            <section class="field mb-4">
                <input asp-for="@this.Model.YearOfManufacture" class="form-control" placeholder="Year of manufacture" type="number" />
                <span asp-validation-for="@this.Model.YearOfManufacture" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <button type="submit" class="btn btn-primary btn-block">Edit</button>
            <a href="javascript:window.history.back();" class="btn btn-warning btn-block">Cancel</a>
        </section>
    </form>
</div>

@section Scripts {
    <script src="~/lib/tinymce/tinymce.min.js" type="text/javascript"></script>

    <script>
        tinymce.init({
            selector: "textarea",
            plugins: [
                "image paste table link code media"
            ]
        });

        $('.custom-file-input').on("change", function () {
            var fileName = $(this).val().split("\\").pop();
            $(this).next('.custom-file-label').html(fileName);
        });
    </script>
}

@section CustomCss {
    <style>
        .custom-file-label {
            text-align: left;
        }

        .dropdown > button {
            background-color: rgb(255, 255, 255);
            border: 1px solid #d1d3e2;
        }
    </style>
}