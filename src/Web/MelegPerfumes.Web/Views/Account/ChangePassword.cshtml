@model UserChangePasswordInputModel

@{
    ViewData["Title"] = "Change password";
    Layout = "_BubblesLayout";
}

<div class="text-center w-75 w-md-50 mx-auto">
    <h2>@ViewData["Title"]</h2>
    <hr />

    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="form-group">
            <label>Email</label>
            <input class="form-control" value="@Model.Email" disabled />
        </div>
        <div class="form-group">
            <label asp-for="@Model.OldPassword"></label>
            <input class="form-control" asp-for="@Model.OldPassword" />
            <span asp-validation-for="@Model.OldPassword" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="@Model.NewPassword"></label>
            <input class="form-control" asp-for="@Model.NewPassword" />
            <span asp-validation-for="@Model.NewPassword" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="@Model.ConfirmPassword"></label>
            <input class="form-control" asp-for="@Model.ConfirmPassword" />
            <span asp-validation-for="@Model.ConfirmPassword" class="text-danger"></span>
        </div>
        <div class="form-group">
            <button type="submit" class="btn btn-primary w-100 p-3">Change password</button>
        </div>
    </form>
</div> 