@model ProductDetailsViewModel

@{
    void DisplayComments(int? parentId)
    {
        var comments = this.Model.Comments.Where(c => c.ParentId == parentId);

        if (!comments.Any())
        {
            return;
        }

        <div class="comments-container">
            <ul class="comments-list">
                @foreach (var comment in comments)
                {
                    <li>
                        <div class="comment-main-level">
                            <div class="comment-avatar"><img src="https://res.cloudinary.com/dxfq3iotg/image/upload/v1574583246/AAA/2.jpg" alt=""></div>
                            <div class="comment-box">
                                <div class="comment-head">
                                    <h6 class="comment-name by-name">
                                        <span class="author">@comment.UserUserName</span>
                                        @if (comment.UserUserName == this.User.Identity.Name)
                                        {
                                            <span class="tag-author">author</span>
                                        }
                                    </h6>
                                    <div class="text-muted small">
                                        <time datetime="@comment.CreatedOn.ToString("O")"></time>
                                        @if (comment.ParentId == null && this.User.Identity.IsAuthenticated)
                                        {
                                            <i class="fa fa-reply" onclick="showAddCommentForm(@comment.Id)"></i>
                                        }
                                    <div>
                                            <i id="heart-@comment.Id" class="fa fa-heart" onclick="sendVote(@comment.Id)"></i>
                                        <span id="votesCount-@comment.Id" style="float: right;">@comment.VotesCount</span>
                                    </div>
                                    </div>
                                </div>
                                <div class="comment-content">
                                    @Html.Raw(comment.SanitizedContent)
                                </div>
                            </div>
                        </div>
                        @{ DisplayComments(comment.Id); }
                    </li>
                }
            </ul>
        </div>
    }
    <form id="votesForm" method="post"></form>
    }

    @if (this.User.Identity.IsAuthenticated)
    {
        <div class="px-4 pt-3"> <button type="button" class="btn btn-primary btn-comment float-right" onclick="showAddCommentForm(0)"><i class="fa fa-plus"></i>&nbsp; Comment</button> </div>
        <div class="clearfix"></div>
    }
    @{ DisplayComments(null); }
    <section style="margin-left: 1rem; margin-right: 1rem;">
        <form asp-controller="Comments" asp-action="Create" method="post" id="AddCommentForm" style="display: none">
            <input type="hidden" name="ProductId" value="@this.Model.Id" />
            <input type="hidden" name="ParentId" value="0" />
            <div>
                <label for="Content"></label>
                <textarea name="Content" id="Content" class="form-control"></textarea>
            </div>
            <div>
                <input type="submit" class="btn btn-primary btn-comment" value="Add comment" />
            </div>
        </form>
    </section>

    <script src="/lib/tinymce/tinymce.min.js" type="text/javascript"></script>
    <script type="text/javascript">
        tinymce.init({
            selector: "textarea",
            plugins: ["image paste table link code media"]
        });
    </script>

    @section Scripts {
        <script>
            function showAddCommentForm(parentId) {
                $("#AddCommentForm input[name='ParentId']").val(parentId);
                $("#AddCommentForm").show();
                $([document.documentElement, document.body]).animate({
                    scrollTop: $("#AddCommentForm").offset().top
                }, 1000);
            }
        </script>
    }

    <script>
        function sendVote(commentId) {
            let token = $("#votesForm input[name=__RequestVerificationToken]").val();
            let json = { commentId: commentId }; // votesInputModel
 
            $.ajax({
                url: "/api/votes",
                type: "POST",
                data: JSON.stringify(json),
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                headers: { 'X-CSRF-TOKEN': token },
                success: function (data) {
                    $(`#votesCount-${commentId}`).html(data.votesCount);
                    if (data.isUpVoted === true) {
                        $(`#heart-${commentId}`).addClass("voted");
                    } else {
                        $(`#heart-${commentId}`).removeClass("voted");
                    }
                }
            });
        }
    </script>

    <link href="~/css/comments.css" rel="stylesheet" asp-append-version="true" />
