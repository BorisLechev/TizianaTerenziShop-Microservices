@model ProductDetailsViewModel

@{
    void DisplayComments(int? parentId)
    {
        var comments = this.Model.Comments.Where(c => c.ParentId == parentId);

        if (!comments.Any())
        {
            return;
        }

        @foreach (var comment in comments)
        {
            <div class="container-fluid mt-100">
                <div class="row">
                    <div class="col-md-12">
                        <div class="card mb-4">
                            <div class="card-header">
                                <div class="media flex-wrap w-100 align-items-center">
                                    <img src="https://res.cloudinary.com/dxfq3iotg/image/upload/v1574583246/AAA/2.jpg" class="d-block ui-w-40 rounded-circle" alt="">
                                    <div class="media-body ml-3">
                                        @comment.IssuerUserName
                                        <div class="text-muted small">@comment.CreatedOn</div>
                                    </div>
                                    <div class="text-muted small ml-3">
                                        <div class="px-4 pt-3"> <button type="button" class="btn btn-secondary" onclick="showAddCommentForm(@comment.Id)"><i class="fa fa-plus"></i>&nbsp; Answer</button> </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <article>
                                    @Html.Raw(comment.SanitizedContent)
                                </article>
                                @{ DisplayComments(comment.Id); }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
}

<main id="main">
    <section>
        <section class="page-container">
            <section class="section-product-details">
                <section class="row">
                    <article class="image-wrapper">
                        <section class="inner-image-wrapper">
                            <section class="image-container">
                                @*<input class="slider-input" checked type=radio name="slider" id="slide1" />
                                    <input class="slider-input" type=radio name="slider" id="slide2" />
                                    <input class="slider-input" type=radio name="slider" id="slide3" />*@
                                <div class="slider-wrapper">
                                    <div class=inner>
                                        <article>
                                            <img class="product-image" src="@Model.Picture" />
                                        </article>
                                        @*<article>
                                                <img class="product-image" src="@Model.Picture" />
                                            </article>
                                            <article>
                                                <img class="product-image" src="@Model.Picture" />
                                            </article>*@
                                    </div>
                                </div>
                                @*<div class="slider-prev-next-control">
                                        <label for=slide1></label>
                                        <label for=slide2></label>
                                        <label for=slide3></label>
                                    </div>
                                    <div class="slider-dot-control">
                                        <label for=slide1></label>
                                        <label for=slide2></label>
                                        <label for=slide3></label>
                                    </div>*@
                            </section>
                        </section>
                    </article>
                    <article class="details-wrapper">
                        <header class="details-header-container">
                            <h3 class="product-title">@Model.Name</h3>
                        </header>
                        <main class="details-main-container">
                            <dl>
                                <dt class="notes-section">
                                    <h6 class="section-title">Notes</h6>
                                </dt>
                                <dd class="notes"><p>@string.Join(", ", Model.Notes)</p></dd>
                            </dl>
                            <section class="product-price-container">€ @Model.Price EUR</section>
                            <section class="product-quantity-container">
                                <span class="product-quantity-inner-container">
                                    <span class="quantity">1</span>
                                    <span class="increase-btn"></span>
                                    <span class="decrease-btn"></span>
                                </span>
                            </section>
                            <section class="btn-container">
                                <a class="button">Add to cart</a>
                            </section>
                        </main>
                    </article>
                </section>
            </section>
        </section>
        <section class="description">
            <header>
                <h5 class="description-title">Description</h5>
            </header>
            <main>
                <p>@Html.Raw(Model.Description)</p>
            </main>
        </section>

        <div class="px-4 pt-3"> <button type="button" class="btn btn-primary btn-comment float-right" onclick="showAddCommentForm(0)"><i class="fa fa-plus"></i>&nbsp; Comment</button> </div>
        <div class="clearfix"></div>
        @{ DisplayComments(null); }
    </section>
    <div>
        <form asp-controller="Comments" asp-action="Create" method="post" id="AddCommentForm" style="display: none">
            <input type="hidden" name="ProductId" value="@this.Model.Id" />
            <input type="hidden" name="ParentId" value="0" />
            <div>
                <label for="Content"></label>
                <textarea name="Content" id="Content" class="form-control"></textarea>
            </div>
            <div>
                <input type="submit" class="btn btn-primary btn-comment" value="Add comment" />
            </div>
        </form>
    </div>
</main>

<script src="/lib/tinymce/tinymce.min.js" type="text/javascript"></script>
<script type="text/javascript">
    tinymce.init({
        selector: "textarea",
        plugins: ["image paste table link code media"]
    });
</script>

@section Scripts {
    <script>
        function showAddCommentForm(parentId) {
            $("#AddCommentForm input[name='ParentId']").val(parentId);
            $("#AddCommentForm").show();
            $([document.documentElement, document.body]).animate({
                scrollTop: $("#AddCommentForm").offset().top
            }, 1000);
        }
    </script>
}

<partial name="_TestimonialsPartial" />

@section CustomCss {
    <link href="~/css/product-details.css" rel="stylesheet" asp-append-version="true" />
}