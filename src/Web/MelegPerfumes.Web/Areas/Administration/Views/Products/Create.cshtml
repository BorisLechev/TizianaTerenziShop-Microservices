@model ProductCreateInputModel

@{
    ViewData["Title"] = "Create a Product";
}

<div class="w-75 w-md-50 text-center mx-auto">
    <div class="row space-top">
        <div class="col-md-12">
            <h2 class="title">@ViewData["Title"]</h2>
        </div>
    </div>
    <hr />
    <div asp-validation-summary="All" class="text-danger"></div>
    <form method="post">
        <section class="form-group">
            <label asp-for="Name">Name</label>
            <section class="field mb-4">
                <input asp-for="Name" class="form-control" placeholder="Name" type="text" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="ProductType" class="control-label">Product Type</label>
            <section class="field mb-4">
                <select class="form-control selectpicker" data-live-search="true" title="Select Product Type..."
                        id="productType" asp-items="@Model.ProductTypes">
                    <option value="OtherProductType">Other...</option>
                </select>
                <input asp-for="ProductType" class="form-control mt-1" id="productTypeSelected" style="display: none;" />
                <span asp-validation-for="ProductType" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="FragranceGroup" class="control-label">Fragrance Group</label>
            <section class="field mb-4">
                <select class="form-control selectpicker" data-live-search="true" title="Select Fragrance Group..."
                        id="fragranceGroup" asp-items="@Model.FragranceGroups">
                    <option value="OtherFragranceGroup">Other...</option>
                </select>
                <input asp-for="FragranceGroup" class="form-control mt-1" id="fragranceGroupSelected" style="display: none;" />
                <span asp-validation-for="FragranceGroup" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="Notes" class="control-label">Notes</label>
            <section class="field mb-4">
                <select class="form-control selectpicker" data-live-search="true" multiple title="Select Notes..."
                        id="note" asp-items="@Model.Notes">
                    <option value="OtherNote">Other...</option>
                </select>
                <input asp-for="Notes" class="form-control mt-1" id="noteSelected" style="display: none;" />
                <span asp-validation-for="Notes" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="Description">Description</label>
            <section class="field mb-4">
                <input asp-for="Description" id="description" class="form-control" placeholder="Description" type="text" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="Price">Price</label>
            <section class="field mb-4">
                <input class="form-control" asp-for="Price" placeholder="Price" type="number" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </section>
        </section>
        <section class="form-group">
            <label asp-for="Picture">Image file</label>
            <section class="field mb-4">
                <div class="custom-file">
                    <input asp-for="Picture" type="file" class="custom-file-input form-control" id="customFile">
                    <label asp-for="Picture" class="custom-file-label" for="customFile">Choose file</label>
                </div>
            </section>
            @*<label asp-for="Picture">Image file</label>*@
            @*<section class="field mb-4">
                <input asp-for="Picture" class="form-control" placeholder="Image file" type="file" />
                <span asp-validation-for="Picture" class="text-danger"></span>
            </section>*@
        </section>
        <section class="form-group">
            <label asp-for="YearOfManufacture">Year of manufacture</label>
            <section class="field mb-4">
                <input asp-for="YearOfManufacture" class="form-control" placeholder="Year of manufacture" type="number" />
                <span asp-validation-for="YearOfManufacture"></span>
            </section>
        </section>
        <section class="form-group">
            <button type="submit" class="btn btn-primary btn-block">Create</button>
        </section>
    </form>
</div> 

@section Scripts {
    <script>
        var productType = $('#productType');
        var selectedProductType = $('#productTypeSelected');

        productType.find('option:first').appendTo(productType);

        productType.change(function () {
            var value = $(this).val();

            if (value == 'OtherProductType') {
                selectedProductType.show();
                selectedProductType.val('');
                selectedProductType.trigger('focus');
            } else {
                selectedProductType.hide();
                selectedProductType.val(value);
                $('#fragranceGroup').trigger('focus');
            }
        });

        var fragranceGroup = $('#fragranceGroup');
        var selectedFragranceGroup = $('#fragranceGroupSelected');

        fragranceGroup.find('option:first').appendTo(fragranceGroup);

        fragranceGroup.change(function () {
            var value = $(this).val();

            if (value == 'OtherFragranceGroup') {
                selectedFragranceGroup.show();
                selectedFragranceGroup.val('');
                selectedFragranceGroup.trigger('focus');
            } else {
                selectedFragranceGroup.hide();
                selectedFragranceGroup.val(value);
                $('#note').trigger('focus');
            }
        });

        var note = $('#note');
        var selectedNote = $('#noteSelected');

        note.find('option:first').appendTo(note);

        note.change(function () {
            var value = $(this).val();

            if (value == 'OtherNote') {
                selectedNote.show();
                selectedNote.val('');
                selectedNote.trigger('focus');
            } else {
                selectedNote.hide();
                selectedNote.val(value);
            }
        });
    </script>
}

@section CustomCss {
    <style>
        .custom-file-label {
            padding-left: 1rem;
            padding-right: 1rem;
            text-align: left;
            border-radius: 50px;
        }

        .custom-file-label:after {
            border-radius: 0 20px 20px 0;
        }
    </style>
}